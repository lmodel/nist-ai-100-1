@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix nist_ai_100_1: <https://w3id.org/lmodel/nist-ai-100-1/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nist_ai_100_1:AiActor a sh:NodeShape ;
    rdfs:comment """An organization or individual that plays an active role in the AI
system lifecycle. AI actors include those who deploy or operate
AI as well as those who inform via formal or quasi-formal norms
and guidance (OECD 2019).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "AI actor task category." ;
            sh:in ( "AI_DESIGN" "AI_DEVELOPMENT" "AI_DEPLOYMENT" "OPERATION_AND_MONITORING" "TEVV" "HUMAN_FACTORS" "DOMAIN_EXPERT" "AI_IMPACT_ASSESSMENT" "PROCUREMENT" "GOVERNANCE_AND_OVERSIGHT" "THIRD_PARTY_ENTITIES" "END_USERS" "AFFECTED_INDIVIDUALS_OR_COMMUNITIES" "OTHER_AI_ACTORS" "GENERAL_PUBLIC" ) ;
            sh:order 0 ;
            sh:path nist_ai_100_1:actor_task ],
        [ sh:datatype xsd:boolean ;
            sh:description """Whether the actor or task is a Test, Evaluation, Verification, and
Validation (TEVV) actor / task.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_ai_100_1:is_tevv ],
        [ sh:description "The AI lifecycle stage(s) the element applies to." ;
            sh:in ( "PLAN_AND_DESIGN" "COLLECT_AND_PROCESS_DATA" "BUILD_AND_USE_MODEL" "VERIFY_AND_VALIDATE" "DEPLOY_AND_USE" "OPERATE_AND_MONITOR" ) ;
            sh:order 1 ;
            sh:path nist_ai_100_1:lifecycle_stage ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path rdfs:label ],
        [ sh:description """Whether the actor is part of the *primary* AI RMF audience or the
*informing* People-and-Planet audience.""" ;
            sh:in ( "PRIMARY" "INFORMING" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path nist_ai_100_1:audience ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:description ] ;
    sh:targetClass nist_ai_100_1:AiActor .

nist_ai_100_1:AiRmfFramework a sh:NodeShape ;
    rdfs:comment """Root container that bundles the AI RMF Core (Functions) with
foundational concepts (trustworthiness characteristics,
lifecycle, actors, risks, harms), profiles, and Framework
attributes. Designed for serialising the Framework or a tailored
instance of it as a single JSON / YAML document.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path rdfs:seeAlso ],
        [ sh:class nist_ai_100_1:AiRmfProfile ;
            sh:description "AI RMF profiles defined alongside this Framework instance." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path nist_ai_100_1:profiles ],
        [ sh:class nist_ai_100_1:RmfAttribute ;
            sh:description "Design attributes of the AI RMF (Appendix D)." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path nist_ai_100_1:attributes ],
        [ sh:class nist_ai_100_1:Function ;
            sh:description "The four AI RMF Core functions and their content." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path nist_ai_100_1:functions ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dcterms:title ],
        [ sh:class nist_ai_100_1:AiActorTask ;
            sh:description "AI actor task categories (Appendix A)." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path nist_ai_100_1:actor_tasks ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path rdfs:label ],
        [ sh:class nist_ai_100_1:AiSystemDimension ;
            sh:description "The AI system dimensions (Figure 2)." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path nist_ai_100_1:dimensions ],
        [ sh:class nist_ai_100_1:TrustworthinessCharacteristic ;
            sh:description "The seven characteristics of trustworthy AI." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path nist_ai_100_1:trustworthiness_characteristics ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path schema1:identifier ],
        [ sh:class nist_ai_100_1:AiSpecificRisk ;
            sh:description "AI-specific risks compared to traditional software (Appendix B)." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path nist_ai_100_1:ai_specific_risks ],
        [ sh:class nist_ai_100_1:AiLifecycleStage ;
            sh:description "The AI lifecycle stages (Figure 2)." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path nist_ai_100_1:lifecycle_stages ],
        [ sh:class nist_ai_100_1:AiRmfDocument ;
            sh:description "Publication metadata of the framework instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path nist_ai_100_1:document ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path dcterms:description ],
        [ sh:class nist_ai_100_1:RiskMeasurementChallenge ;
            sh:description "Identified challenges in measuring AI risk." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path nist_ai_100_1:risk_measurement_challenges ],
        [ sh:class nist_ai_100_1:HumanAiInteractionIssue ;
            sh:description "Human-AI interaction considerations (Appendix C)." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path nist_ai_100_1:human_ai_interaction_issues ] ;
    sh:targetClass nist_ai_100_1:AiRmfFramework .

nist_ai_100_1:Bias a sh:NodeShape ;
    rdfs:comment """A form of AI bias - a deviation that may be perpetuated or
amplified by AI systems. NIST identifies three major categories:
systemic, computational/statistical, and human-cognitive
(Part 1 §3.7; NIST SP 1270).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Category or categories of bias addressed." ;
            sh:in ( "SYSTEMIC" "COMPUTATIONAL_AND_STATISTICAL" "HUMAN_COGNITIVE" ) ;
            sh:order 0 ;
            sh:path nist_ai_100_1:bias_category ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path rdfs:label ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path schema1:identifier ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcterms:description ] ;
    sh:targetClass nist_ai_100_1:Bias .

nist_ai_100_1:Harm a sh:NodeShape ;
    rdfs:comment """A negative impact that may be experienced by individuals,
groups, communities, organizations, society, the environment, or
the planet (Figure 1).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """Magnitude or degree of consequences if the event occurs (free
text or qualitative scale).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_ai_100_1:magnitude ],
        [ sh:description "The high-level harm category (people / organization / ecosystem)." ;
            sh:in ( "HARM_TO_PEOPLE" "HARM_TO_AN_ORGANIZATION" "HARM_TO_AN_ECOSYSTEM" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path nist_ai_100_1:harm_category ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:description ],
        [ sh:description "The sub-category when harm is to people (individual / group / societal)." ;
            sh:in ( "INDIVIDUAL" "GROUP_OR_COMMUNITY" "SOCIETAL" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nist_ai_100_1:harm_to_people_subcategory ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:title ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path rdfs:seeAlso ],
        [ sh:class schema1:Thing ;
            sh:description """Entities (people, organizations, ecosystems) the risk or harm
may affect.""" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path nist_ai_100_1:affects ] ;
    sh:targetClass nist_ai_100_1:Harm .

nist_ai_100_1:PlaybookCollection a sh:NodeShape ;
    rdfs:comment """A container for a set of PlaybookEntry instances - the
serialisation root for an AI RMF Playbook companion document.
Validate with ``linkml-validate --target-class PlaybookCollection``;
the canonical tree-root for the schema is ``AiRmfFramework``.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nist_ai_100_1:PlaybookEntry ;
            sh:description "The Playbook entries in a `PlaybookCollection`." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nist_ai_100_1:entries ] ;
    sh:targetClass nist_ai_100_1:PlaybookCollection .

nist_ai_100_1:ResidualRisk a sh:NodeShape ;
    rdfs:comment """Risk remaining after risk treatment (ISO Guide 73). Documenting
residual risks helps system providers consider risks of deploying
the AI product and informs end users about potential negative
impacts.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description """Magnitude or degree of consequences if the event occurs (free
text or qualitative scale).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:magnitude ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path rdfs:label ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path rdfs:seeAlso ],
        [ sh:description "The chosen risk treatment option." ;
            sh:in ( "MITIGATING" "TRANSFERRING" "AVOIDING" "ACCEPTING" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path nist_ai_100_1:risk_response ],
        [ sh:description "Whether the impact is positive, negative, or both." ;
            sh:in ( "POSITIVE" "NEGATIVE" "MIXED" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path nist_ai_100_1:impact_sign ],
        [ sh:class nist_ai_100_1:Impact ;
            sh:description "The impacts that contribute to a risk." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path nist_ai_100_1:related_impacts ],
        [ sh:class nist_ai_100_1:AiSystem ;
            sh:description "The AI system a risk pertains to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path nist_ai_100_1:affects_system ],
        [ sh:description "Trustworthiness characteristic(s) the element pertains to." ;
            sh:in ( "VALID_AND_RELIABLE" "SAFE" "SECURE_AND_RESILIENT" "ACCOUNTABLE_AND_TRANSPARENT" "EXPLAINABLE_AND_INTERPRETABLE" "PRIVACY_ENHANCED" "FAIR_WITH_HARMFUL_BIAS_MANAGED" ) ;
            sh:order 6 ;
            sh:path nist_ai_100_1:trustworthiness_characteristic ],
        [ sh:description "The AI lifecycle stage(s) the element applies to." ;
            sh:in ( "PLAN_AND_DESIGN" "COLLECT_AND_PROCESS_DATA" "BUILD_AND_USE_MODEL" "VERIFY_AND_VALIDATE" "DEPLOY_AND_USE" "OPERATE_AND_MONITOR" ) ;
            sh:order 5 ;
            sh:path nist_ai_100_1:lifecycle_stage ],
        [ sh:datatype xsd:float ;
            sh:description """Estimated probability of the event occurring (0.0 to 1.0). The
AI RMF leaves quantification approaches to the implementer.""" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_ai_100_1:likelihood ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:boolean ;
            sh:defaultValue true ;
            sh:description """Whether this risk represents risk remaining after risk treatment
(residual risk per ISO Guide 73).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_ai_100_1:is_residual ] ;
    sh:targetClass nist_ai_100_1:ResidualRisk .

nist_ai_100_1:Risk a sh:NodeShape ;
    rdfs:comment """The composite measure of an event's probability of occurring and
the magnitude or degree of the consequences of that event. When
considering negative impact, risk is a function of (1) the
negative impact or magnitude of harm and (2) the likelihood of
occurrence (Adapted from ISO 31000:2018; OMB Circular A-130:2016).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """Magnitude or degree of consequences if the event occurs (free
text or qualitative scale).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:magnitude ],
        [ sh:datatype xsd:boolean ;
            sh:description """Whether this risk represents risk remaining after risk treatment
(residual risk per ISO Guide 73).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_ai_100_1:is_residual ],
        [ sh:datatype xsd:float ;
            sh:description """Estimated probability of the event occurring (0.0 to 1.0). The
AI RMF leaves quantification approaches to the implementer.""" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_ai_100_1:likelihood ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path rdfs:label ],
        [ sh:description "Trustworthiness characteristic(s) the element pertains to." ;
            sh:in ( "VALID_AND_RELIABLE" "SAFE" "SECURE_AND_RESILIENT" "ACCOUNTABLE_AND_TRANSPARENT" "EXPLAINABLE_AND_INTERPRETABLE" "PRIVACY_ENHANCED" "FAIR_WITH_HARMFUL_BIAS_MANAGED" ) ;
            sh:order 6 ;
            sh:path nist_ai_100_1:trustworthiness_characteristic ],
        [ sh:description "The chosen risk treatment option." ;
            sh:in ( "MITIGATING" "TRANSFERRING" "AVOIDING" "ACCEPTING" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path nist_ai_100_1:risk_response ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path dcterms:description ],
        [ sh:class nist_ai_100_1:Impact ;
            sh:description "The impacts that contribute to a risk." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path nist_ai_100_1:related_impacts ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path schema1:identifier ],
        [ sh:class nist_ai_100_1:AiSystem ;
            sh:description "The AI system a risk pertains to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path nist_ai_100_1:affects_system ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path dcterms:title ],
        [ sh:description "The AI lifecycle stage(s) the element applies to." ;
            sh:in ( "PLAN_AND_DESIGN" "COLLECT_AND_PROCESS_DATA" "BUILD_AND_USE_MODEL" "VERIFY_AND_VALIDATE" "DEPLOY_AND_USE" "OPERATE_AND_MONITOR" ) ;
            sh:order 5 ;
            sh:path nist_ai_100_1:lifecycle_stage ],
        [ sh:description "Whether the impact is positive, negative, or both." ;
            sh:in ( "POSITIVE" "NEGATIVE" "MIXED" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path nist_ai_100_1:impact_sign ] ;
    sh:targetClass nist_ai_100_1:Risk .

nist_ai_100_1:RiskTolerance a sh:NodeShape ;
    rdfs:comment """The organization's or AI actor's readiness to bear risk in order
to achieve its objectives (Adapted from ISO Guide 73). Risk
tolerance is highly contextual and application- and use-case
specific.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text statement of a risk tolerance level or threshold." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_ai_100_1:tolerance_statement ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path rdfs:label ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "Legal or regulatory requirements influencing a risk tolerance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:legal_basis ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path schema1:identifier ] ;
    sh:targetClass nist_ai_100_1:RiskTolerance .

nist_ai_100_1:AiActorTask a sh:NodeShape ;
    rdfs:comment """A category of task performed by AI actors (Appendix A). Each
task is associated with one or more lifecycle stages and a
typical set of actor roles.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path rdfs:label ],
        [ sh:description "The AI lifecycle stage(s) the element applies to." ;
            sh:in ( "PLAN_AND_DESIGN" "COLLECT_AND_PROCESS_DATA" "BUILD_AND_USE_MODEL" "VERIFY_AND_VALIDATE" "DEPLOY_AND_USE" "OPERATE_AND_MONITOR" ) ;
            sh:order 2 ;
            sh:path nist_ai_100_1:lifecycle_stage ],
        [ sh:description "The AI system dimension the element applies to." ;
            sh:in ( "APPLICATION_CONTEXT" "DATA_AND_INPUT" "AI_MODEL" "TASK_AND_OUTPUT" "PEOPLE_AND_PLANET" ) ;
            sh:order 3 ;
            sh:path nist_ai_100_1:ai_dimension ],
        [ sh:datatype xsd:string ;
            sh:description "Representative actor roles that perform an AI actor task." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:typical_actors ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:title ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path schema1:identifier ],
        [ sh:description "Which AI actor task category an `AiActorTask` instance represents." ;
            sh:in ( "AI_DESIGN" "AI_DEVELOPMENT" "AI_DEPLOYMENT" "OPERATION_AND_MONITORING" "TEVV" "HUMAN_FACTORS" "DOMAIN_EXPERT" "AI_IMPACT_ASSESSMENT" "PROCUREMENT" "GOVERNANCE_AND_OVERSIGHT" "THIRD_PARTY_ENTITIES" "END_USERS" "AFFECTED_INDIVIDUALS_OR_COMMUNITIES" "OTHER_AI_ACTORS" "GENERAL_PUBLIC" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path nist_ai_100_1:task_kind ] ;
    sh:targetClass nist_ai_100_1:AiActorTask .

nist_ai_100_1:AiLifecycleStage a sh:NodeShape ;
    rdfs:comment """A stage of the AI lifecycle (Figure 2): Plan and Design,
Collect and Process Data, Build and Use Model, Verify and
Validate, Deploy and Use, or Operate and Monitor.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Which AI lifecycle stage an `AiLifecycleStage` instance represents." ;
            sh:in ( "PLAN_AND_DESIGN" "COLLECT_AND_PROCESS_DATA" "BUILD_AND_USE_MODEL" "VERIFY_AND_VALIDATE" "DEPLOY_AND_USE" "OPERATE_AND_MONITOR" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path nist_ai_100_1:stage_kind ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcterms:title ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the lifecycle stage incorporates TEVV activities." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:includes_tevv ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path schema1:identifier ] ;
    sh:targetClass nist_ai_100_1:AiLifecycleStage .

nist_ai_100_1:AiRmfDocument a sh:NodeShape ;
    rdfs:comment """Publication metadata for an instance of the AI RMF (e.g., NIST
AI 100-1, January 2023). The Framework is intended to be a
living document, employing a two-number versioning system (major.minor).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:title ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:date ;
            sh:description "Date the document was published." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:issued ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier of the document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:version ],
        [ sh:description """Reference to the source of the element (typically the document
or section it originated from).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path dcterms:source ],
        [ sh:datatype xsd:string ;
            sh:description "The publisher of the document (e.g., NIST)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:publisher ],
        [ sh:description "Digital Object Identifier for the document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path nist_ai_100_1:doi ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcterms:description ] ;
    sh:targetClass nist_ai_100_1:AiRmfDocument .

nist_ai_100_1:AiRmfProfile a sh:NodeShape ;
    rdfs:comment """An implementation of the AI RMF Functions, Categories, and
Subcategories for a specific setting or application based on the
requirements, risk tolerance, and resources of the user (§6).
Profiles may be use-case-specific, temporal (current or target),
or cross-sectoral.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description """For temporal target profiles - the outcomes needed to achieve the
desired AI risk management goals.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_ai_100_1:target_state ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcterms:description ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description """The sector, industry, technology, or end-use application a
profile addresses (e.g., "hiring", "fair housing").""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_ai_100_1:sector ],
        [ sh:datatype xsd:string ;
            sh:description """For temporal current profiles - how AI is currently being managed
and related risks in terms of current outcomes.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:current_state ],
        [ sh:description "The kind of AI RMF Profile." ;
            sh:in ( "USE_CASE" "TEMPORAL_CURRENT" "TEMPORAL_TARGET" "CROSS_SECTORAL" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path nist_ai_100_1:profile_type ],
        [ sh:class nist_ai_100_1:Subcategory ;
            sh:description "Subcategories that a profile implements or addresses." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path nist_ai_100_1:addresses ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path rdfs:seeAlso ] ;
    sh:targetClass nist_ai_100_1:AiRmfProfile .

nist_ai_100_1:AiSpecificRisk a sh:NodeShape ;
    rdfs:comment """A risk that is new or increased for AI-based technology compared
to traditional software (Appendix B) - e.g., data quality, model
drift, opacity, scale and complexity, pre-trained model
uncertainty, emergent properties, privacy aggregation, or
environmental cost.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:title ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path rdfs:seeAlso ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass nist_ai_100_1:AiSpecificRisk .

nist_ai_100_1:AiSystemDimension a sh:NodeShape ;
    rdfs:comment """A socio-technical dimension of an AI system (Figure 2):
Application Context, Data and Input, AI Model, Task and Output,
or People and Planet.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:title ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcterms:description ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path schema1:identifier ],
        [ sh:description "Which AI system dimension an `AiSystemDimension` instance represents." ;
            sh:in ( "APPLICATION_CONTEXT" "DATA_AND_INPUT" "AI_MODEL" "TASK_AND_OUTPUT" "PEOPLE_AND_PLANET" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path nist_ai_100_1:dimension_kind ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path rdfs:label ] ;
    sh:targetClass nist_ai_100_1:AiSystemDimension .

nist_ai_100_1:Category a sh:NodeShape ;
    rdfs:comment """A category within an AI RMF Core function (e.g., "GOVERN 1:
Policies, processes, procedures, and practices ... are in place,
transparent, and implemented effectively"). Categories group
related subcategories.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nist_ai_100_1:Subcategory ;
            sh:description "Subcategories that belong to a Category." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path nist_ai_100_1:subcategories ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:description ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of a Category (e.g., \"GOVERN 1\")." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_ai_100_1:category_id ;
            sh:pattern "^(GOVERN|MAP|MEASURE|MANAGE) [0-9]+$" ],
        [ sh:description """Identifier for the category, typically using the
"FUNCTION N" form (e.g., "GOVERN 1").""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description """The outcome statement of a Category or Subcategory - the desired
result of carrying out its actions.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:outcome ] ;
    sh:targetClass nist_ai_100_1:Category .

nist_ai_100_1:Function a sh:NodeShape ;
    rdfs:comment """A top-level AI RMF Core function. Each function organizes AI risk
management activities at the highest level. GOVERN applies across
all stages; MAP, MEASURE, and MANAGE apply to AI-system-specific
contexts and lifecycle stages.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:description ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcterms:title ],
        [ sh:class nist_ai_100_1:Category ;
            sh:description "Categories that belong to a Function." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path nist_ai_100_1:categories ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "The function code (GOVERN, MAP, MEASURE, or MANAGE)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_ai_100_1:function_code ;
            sh:pattern "^(GOVERN|MAP|MEASURE|MANAGE)$" ] ;
    sh:targetClass nist_ai_100_1:Function .

nist_ai_100_1:HumanAiInteractionIssue a sh:NodeShape ;
    rdfs:comment """An issue that merits further consideration in human-AI
interaction (Appendix C) - e.g., clear human roles and
responsibilities, systemic and human-cognitive biases in design,
variability of human-AI interaction outcomes, complexity of
presenting AI system information to humans.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path rdfs:seeAlso ] ;
    sh:targetClass nist_ai_100_1:HumanAiInteractionIssue .

nist_ai_100_1:PlaybookEntry a sh:NodeShape ;
    rdfs:comment """A single AI RMF Playbook entry - an enrichment of a Core
subcategory with prose discussion, suggested actions,
documentation questions, references, and topic tags.

Attribute names use the same identifiers found in the published
NIST AI RMF Playbook JSON (e.g., `section_about`,
`section_actions`) so that the data can be loaded directly.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "References and citations (\"References\" section)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path nist_ai_100_1:section_ref ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text discussion (\"About\" section)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path nist_ai_100_1:section_about ],
        [ sh:datatype xsd:string ;
            sh:description """Documentation questions and transparency resources
("Documentation" section).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path nist_ai_100_1:section_doc ],
        [ sh:datatype xsd:string ;
            sh:description "Outcome statement of the subcategory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_ai_100_1:description ],
        [ sh:datatype xsd:string ;
            sh:description "Bulleted suggested actions (\"Actions\" section)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path nist_ai_100_1:section_actions ],
        [ sh:datatype xsd:string ;
            sh:description """Subcategory identifier (e.g., "GOVERN 1.1"). Mirrors the
AI RMF Subcategory `subcategory_id`.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:title ],
        [ sh:datatype xsd:string ;
            sh:description """Topic tags (e.g., "Legal and Regulatory", "Validity and
Reliability").""" ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path nist_ai_100_1:topic ],
        [ sh:datatype xsd:string ;
            sh:description """Category code in the form "FUNCTION-N" (e.g., "GOVERN-1")
as used in the Playbook.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_ai_100_1:category ],
        [ sh:datatype xsd:string ;
            sh:description """AI actor categories the entry applies to. Free-text to
preserve the casing of the source data (e.g., "Governance
and Oversight").""" ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path nist_ai_100_1:ai_actors ],
        [ sh:datatype xsd:string ;
            sh:description """Function label as serialised in the published Playbook JSON
(Title case - "Govern", "Map", "Measure", "Manage"). For
the controlled enum see `function_kind`.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_ai_100_1:type ] ;
    sh:targetClass nist_ai_100_1:PlaybookEntry .

nist_ai_100_1:RiskMeasurementChallenge a sh:NodeShape ;
    rdfs:comment """A challenge that complicates measurement of AI risks
(Part 1 §1.2.1).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:title ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcterms:description ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path rdfs:seeAlso ],
        [ sh:description "Which risk-measurement challenge a `RiskMeasurementChallenge` represents." ;
            sh:in ( "THIRD_PARTY_SOFTWARE_HARDWARE_AND_DATA" "TRACKING_EMERGENT_RISKS" "AVAILABILITY_OF_RELIABLE_METRICS" "RISK_AT_DIFFERENT_LIFECYCLE_STAGES" "RISK_IN_REAL_WORLD_SETTINGS" "INSCRUTABILITY" "HUMAN_BASELINE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path nist_ai_100_1:challenge_kind ] ;
    sh:targetClass nist_ai_100_1:RiskMeasurementChallenge .

nist_ai_100_1:RmfAttribute a sh:NodeShape ;
    rdfs:comment """A design attribute of the AI RMF (Appendix D) - one of the
qualities the Framework strives to embody (e.g., risk-based,
consensus-driven, plain language, common language, easily usable,
universally applicable, outcome-focused, leveraging existing
standards, law- and regulation-agnostic, living document).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path rdfs:seeAlso ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ] ;
    sh:targetClass nist_ai_100_1:RmfAttribute .

nist_ai_100_1:TrustworthinessCharacteristic a sh:NodeShape ;
    rdfs:comment """A characteristic of a trustworthy AI system (Figure 4 / Part 1
§3). The seven characteristics are inter-related; addressing them
individually does not guarantee trustworthiness, and tradeoffs
are usually involved.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description """True when this characteristic relates to all others
(Accountable and Transparent; shown vertically in Figure 4).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_ai_100_1:is_cross_cutting ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:description ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:boolean ;
            sh:description """True when this characteristic is a necessary condition for
trustworthiness (per Figure 4 - Valid and Reliable is the base
of all others).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:is_base_condition ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path rdfs:label ],
        [ sh:description "Which trustworthiness characteristic a `TrustworthinessCharacteristic` represents." ;
            sh:in ( "VALID_AND_RELIABLE" "SAFE" "SECURE_AND_RESILIENT" "ACCOUNTABLE_AND_TRANSPARENT" "EXPLAINABLE_AND_INTERPRETABLE" "PRIVACY_ENHANCED" "FAIR_WITH_HARMFUL_BIAS_MANAGED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path nist_ai_100_1:characteristic_kind ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path rdfs:seeAlso ] ;
    sh:targetClass nist_ai_100_1:TrustworthinessCharacteristic .

schema1:Thing a sh:NodeShape ;
    rdfs:comment "A generic grouping for any identifiable AI RMF element." ;
    sh:closed false ;
    sh:ignoredProperties ( nist_ai_100_1:dimension_kind nist_ai_100_1:trustworthiness_characteristics nist_ai_100_1:target_state nist_ai_100_1:attributes nist_ai_100_1:lifecycle_stages rdf:type nist_ai_100_1:tolerance_statement nist_ai_100_1:documentation_questions nist_ai_100_1:functions nist_ai_100_1:includes_tevv nist_ai_100_1:risk_measurement_challenges nist_ai_100_1:about_text nist_ai_100_1:is_residual nist_ai_100_1:references_text nist_ai_100_1:document nist_ai_100_1:challenge_kind nist_ai_100_1:outcome nist_ai_100_1:dimensions nist_ai_100_1:actor_tasks nist_ai_100_1:magnitude schema1:version nist_ai_100_1:harm_category nist_ai_100_1:addresses nist_ai_100_1:likelihood nist_ai_100_1:is_base_condition nist_ai_100_1:doi nist_ai_100_1:is_tevv nist_ai_100_1:subcategory_id dcterms:publisher nist_ai_100_1:categories nist_ai_100_1:trustworthiness_characteristic nist_ai_100_1:lifecycle_stage nist_ai_100_1:actor_task nist_ai_100_1:affects_system nist_ai_100_1:is_cross_cutting nist_ai_100_1:topics nist_ai_100_1:impact_sign nist_ai_100_1:category_id nist_ai_100_1:profile_type nist_ai_100_1:human_ai_interaction_issues nist_ai_100_1:audience nist_ai_100_1:risk_response nist_ai_100_1:task_kind nist_ai_100_1:characteristic_kind nist_ai_100_1:subcategories nist_ai_100_1:typical_actors nist_ai_100_1:function_code nist_ai_100_1:profiles nist_ai_100_1:affects nist_ai_100_1:harm_to_people_subcategory nist_ai_100_1:current_state nist_ai_100_1:ai_actor_categories nist_ai_100_1:related_impacts nist_ai_100_1:suggested_actions_text nist_ai_100_1:sector nist_ai_100_1:bias_category dcterms:source dcterms:issued nist_ai_100_1:ai_specific_risks nist_ai_100_1:ai_dimension nist_ai_100_1:stage_kind nist_ai_100_1:legal_basis ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path rdfs:seeAlso ] ;
    sh:targetClass schema1:Thing .

nist_ai_100_1:AiSystem a sh:NodeShape ;
    rdfs:comment """An engineered or machine-based system that can, for a given set
of objectives, generate outputs such as predictions,
recommendations, or decisions influencing real or virtual
environments. AI systems are designed to operate with varying
levels of autonomy (Adapted from OECD Recommendation on AI:2019;
ISO/IEC 22989:2022).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path rdfs:label ],
        [ sh:description "The AI system dimension the element applies to." ;
            sh:in ( "APPLICATION_CONTEXT" "DATA_AND_INPUT" "AI_MODEL" "TASK_AND_OUTPUT" "PEOPLE_AND_PLANET" ) ;
            sh:order 1 ;
            sh:path nist_ai_100_1:ai_dimension ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcterms:title ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path schema1:identifier ],
        [ sh:description "The AI lifecycle stage(s) the element applies to." ;
            sh:in ( "PLAN_AND_DESIGN" "COLLECT_AND_PROCESS_DATA" "BUILD_AND_USE_MODEL" "VERIFY_AND_VALIDATE" "DEPLOY_AND_USE" "OPERATE_AND_MONITOR" ) ;
            sh:order 0 ;
            sh:path nist_ai_100_1:lifecycle_stage ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:description ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path rdfs:seeAlso ] ;
    sh:targetClass nist_ai_100_1:AiSystem .

nist_ai_100_1:Impact a sh:NodeShape ;
    rdfs:comment """A positive, negative, or both consequence of an AI system. Impacts
can manifest as opportunities (positive) or threats (negative).""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """Magnitude or degree of consequences if the event occurs (free
text or qualitative scale).""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:magnitude ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:float ;
            sh:description """Estimated probability of the event occurring (0.0 to 1.0). The
AI RMF leaves quantification approaches to the implementer.""" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_ai_100_1:likelihood ],
        [ sh:class schema1:Thing ;
            sh:description """Entities (people, organizations, ecosystems) the risk or harm
may affect.""" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path nist_ai_100_1:affects ],
        [ sh:description "A unique identifier for an element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:description ],
        [ sh:description "Whether the impact is positive, negative, or both." ;
            sh:in ( "POSITIVE" "NEGATIVE" "MIXED" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path nist_ai_100_1:impact_sign ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path rdfs:label ] ;
    sh:targetClass nist_ai_100_1:Impact .

nist_ai_100_1:Subcategory a sh:NodeShape ;
    rdfs:comment """A subcategory within an AI RMF Core category (e.g., "GOVERN 1.1:
Legal and regulatory requirements involving AI are understood,
managed, and documented"). Subcategories express specific
outcomes.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Identifier of a Subcategory (e.g., \"GOVERN 1.1\")." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_ai_100_1:subcategory_id ;
            sh:pattern "^(GOVERN|MAP|MEASURE|MANAGE) [0-9]+\\.[0-9]+$" ],
        [ sh:datatype xsd:string ;
            sh:description """Free-text bulleted list of suggested actions an organization can
take. Corresponds to the AI RMF Playbook "Actions" section.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path nist_ai_100_1:suggested_actions_text ],
        [ sh:description "The AI lifecycle stage(s) the element applies to." ;
            sh:in ( "PLAN_AND_DESIGN" "COLLECT_AND_PROCESS_DATA" "BUILD_AND_USE_MODEL" "VERIFY_AND_VALIDATE" "DEPLOY_AND_USE" "OPERATE_AND_MONITOR" ) ;
            sh:order 3 ;
            sh:path nist_ai_100_1:lifecycle_stage ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description """Free-text list of references, citations, and supporting
resources. Corresponds to the AI RMF Playbook "References"
section.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path nist_ai_100_1:references_text ],
        [ sh:description """Identifier for the subcategory in the "FUNCTION N.M" form
(e.g., "GOVERN 1.1").""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path schema1:identifier ],
        [ sh:description "Trustworthiness characteristic(s) the element pertains to." ;
            sh:in ( "VALID_AND_RELIABLE" "SAFE" "SECURE_AND_RESILIENT" "ACCOUNTABLE_AND_TRANSPARENT" "EXPLAINABLE_AND_INTERPRETABLE" "PRIVACY_ENHANCED" "FAIR_WITH_HARMFUL_BIAS_MANAGED" ) ;
            sh:order 2 ;
            sh:path nist_ai_100_1:trustworthiness_characteristic ],
        [ sh:datatype xsd:string ;
            sh:description """Free-text discussion of the subcategory or related concept.
Corresponds to the AI RMF Playbook "About" section.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path nist_ai_100_1:about_text ],
        [ sh:datatype xsd:string ;
            sh:description """Free-text list of AI Actor categories the entry applies to,
preserving the original case used in the AI RMF Playbook
(e.g., "Governance and Oversight", "TEVV"). For controlled
enum values see `actor_task` (range AiActorTaskEnum).""" ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path nist_ai_100_1:ai_actor_categories ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description """Free-text topic tags applied to a playbook entry (e.g.,
"Governance", "Trustworthy Characteristics", "Validity and
Reliability").""" ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path nist_ai_100_1:topics ],
        [ sh:datatype xsd:string ;
            sh:description """Free-text documentation questions and transparency resources.
Corresponds to the AI RMF Playbook "Documentation" section.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path nist_ai_100_1:documentation_questions ],
        [ sh:datatype xsd:string ;
            sh:description "A short human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description """The outcome statement of a Category or Subcategory - the desired
result of carrying out its actions.""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_ai_100_1:outcome ],
        [ sh:description "Related references." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path rdfs:seeAlso ] ;
    sh:targetClass nist_ai_100_1:Subcategory .

