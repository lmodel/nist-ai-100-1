    {
      "name": "outcome",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/outcome",
      "description": "The outcome statement of a Category or Subcategory - the desired\nresult of carrying out its actions.",
      "in_subset": [
        "framework_core"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "close_mappings": [
        "https://w3id.org/lmodel/nist-csf-v2/prose"
      ],
      "slot_uri": "https://w3id.org/lmodel/nist-ai-100-1/outcome",
      "owner": "Subcategory",
      "domain_of": [
        "Category",
        "Subcategory"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "impact_sign",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/impact_sign",
      "description": "Whether the impact is positive, negative, or both.",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "slot_uri": "https://w3id.org/lmodel/nist-ai-100-1/impact_sign",
      "owner": "Impact",
      "domain_of": [
        "Risk",
        "Impact"
      ],
      "range": "ImpactSignEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "likelihood",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/likelihood",
      "description": "Estimated probability of the event occurring (0.0 to 1.0). The\nAI RMF leaves quantification approaches to the implementer.",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "close_mappings": [
        "https://w3id.org/lmodel/iso27001/LikelihoodRating"
      ],
      "slot_uri": "https://w3id.org/lmodel/nist-ai-100-1/likelihood",
      "owner": "Impact",
      "domain_of": [
        "Risk",
        "Impact"
      ],
      "range": "float",
      "minimum_value": 0.0,
      "maximum_value": 1.0,
      "@type": "SlotDefinition"
    },
    {
      "name": "magnitude",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/magnitude",
      "description": "Magnitude or degree of consequences if the event occurs (free\ntext or qualitative scale).",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "close_mappings": [
        "https://w3id.org/lmodel/iso27001/ImpactRating"
      ],
      "slot_uri": "https://w3id.org/lmodel/nist-ai-100-1/magnitude",
      "owner": "Harm",
      "domain_of": [
        "Risk",
        "Impact",
        "Harm"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "harm_category",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/harm_category",
      "description": "The high-level harm category (people / organization / ecosystem).",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "slot_uri": "https://w3id.org/lmodel/nist-ai-100-1/harm_category",
      "owner": "Harm",
      "domain_of": [
        "Harm"
      ],
      "range": "HarmCategoryEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "harm_to_people_subcategory",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/harm_to_people_subcategory",
      "description": "The sub-category when harm is to people (individual / group / societal).",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "slot_uri": "https://w3id.org/lmodel/nist-ai-100-1/harm_to_people_subcategory",
      "owner": "Harm",
      "domain_of": [
        "Harm"
      ],
      "range": "HarmToPeopleSubcategoryEnum",
      "@type": "SlotDefinition"
    },
    {
