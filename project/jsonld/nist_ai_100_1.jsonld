      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/category_id",
      "description": "Identifier of a Category (e.g., \"GOVERN 1\").",
      "in_subset": [
        "framework_core"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "slot_uri": "https://w3id.org/lmodel/nist-ai-100-1/category_id",
