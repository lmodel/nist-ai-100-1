    {
      "name": "subcategory_id",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/subcategory_id",
      "description": "Identifier of a Subcategory (e.g., \"GOVERN 1.1\").",
      "in_subset": [
        "framework_core"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "slot_uri": "https://w3id.org/lmodel/nist-ai-100-1/subcategory_id",
      "owner": "Subcategory",
