{
  "name": "nist-ai-100-1",
  "description": "LinkML schema for the NIST AI Risk Management Framework\n(AI RMF 1.0), published as NIST AI 100-1 (January 2023).\n\nProvides the structured, machine-readable taxonomy of the\nFramework's foundational concepts (risk, impact, harm, AI system,\nAI actor, lifecycle), the seven characteristics of trustworthy AI,\nand the four Core functions (GOVERN, MAP, MEASURE, MANAGE) together\nwith their categories and subcategories. It also models AI RMF\nProfiles (use-case, temporal, cross-sectoral), the design\nattributes of the Framework, and the AI RMF Playbook companion\ndata shape.",
  "title": "NIST AI Risk Management Framework (AI RMF 1.0)",
  "source": "https://doi.org/10.6028/NIST.AI.100-1",
  "see_also": [
    "https://w3id.org/lmodel/nist-ai-100-1",
    "https://doi.org/10.6028/NIST.AI.100-1",
    "https://www.nist.gov/itl/ai-risk-management-framework"
  ],
  "id": "https://w3id.org/lmodel/nist-ai-100-1",
  "version": "1.0.0",
  "imports": [
    "linkml:types",
    "nist_ai_rmf_common"
  ],
  "license": "Apache-2.0",
