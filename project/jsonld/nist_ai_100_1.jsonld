        "title",
        "description",
        "see_also",
        "challenge_kind"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/RiskMeasurementChallenge",
      "@type": "ClassDefinition"
    },
    {
      "name": "TrustworthinessCharacteristic",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/TrustworthinessCharacteristic",
      "description": "A characteristic of a trustworthy AI system (Figure 4 / Part 1\n\u00a73). The seven characteristics are inter-related; addressing them\nindividually does not guarantee trustworthiness, and tradeoffs\nare usually involved.",
      "in_subset": [
        "trustworthiness"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "characteristic_kind",
        "is_base_condition",
        "is_cross_cutting"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/TrustworthinessCharacteristic",
      "@type": "ClassDefinition"
    },
    {
      "name": "Bias",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Bias",
      "description": "A form of AI bias - a deviation that may be perpetuated or\namplified by AI systems. NIST identifies three major categories:\nsystemic, computational/statistical, and human-cognitive\n(Part 1 \u00a73.7; NIST SP 1270).",
      "in_subset": [
        "trustworthiness"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "related_mappings": [
        "iso29100:PrivacyPrinciple"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "bias_category"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/Bias",
      "@type": "ClassDefinition"
    },
    {
      "name": "Function",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Function",
      "description": "A top-level AI RMF Core function. Each function organizes AI risk\nmanagement activities at the highest level. GOVERN applies across\nall stages; MAP, MEASURE, and MANAGE apply to AI-system-specific\ncontexts and lifecycle stages.",
      "in_subset": [
        "framework_core"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "exact_mappings": [
        "nist_csf:CSFFunction"
      ],
      "related_mappings": [
        "gist_linkml:Function"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "function_code",
        "Function_categories"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/Function",
      "@type": "ClassDefinition"
    },
    {
      "name": "Category",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Category",
      "description": "A category within an AI RMF Core function (e.g., \"GOVERN 1:\nPolicies, processes, procedures, and practices ... are in place,\ntransparent, and implemented effectively\"). Categories group\nrelated subcategories.",
      "in_subset": [
        "framework_core"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "exact_mappings": [
        "nist_csf:CSFCategory"
      ],
      "is_a": "NamedThing",
      "slots": [
        "name",
        "title",
        "description",
        "see_also",
        "category_id",
        "outcome",
        "Category_subcategories",
        "Category_id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/Category",
      "@type": "ClassDefinition"
    },
    {
      "name": "Subcategory",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Subcategory",
      "description": "A subcategory within an AI RMF Core category (e.g., \"GOVERN 1.1:\nLegal and regulatory requirements involving AI are understood,\nmanaged, and documented\"). Subcategories express specific\noutcomes.",
      "in_subset": [
        "framework_core"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "exact_mappings": [
        "nist_csf:CSFSubcategory"
      ],
      "close_mappings": [
        "oscal_catalog:Control",
        "nist_sp_800_53:Control"
      ],
      "is_a": "NamedThing",
      "slots": [
        "name",
        "title",
        "description",
        "see_also",
        "subcategory_id",
        "outcome",
        "trustworthiness_characteristic",
        "lifecycle_stage",
        "about_text",
        "suggested_actions_text",
        "documentation_questions",
        "references_text",
        "topics",
        "ai_actor_categories",
        "Subcategory_id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/Subcategory",
      "@type": "ClassDefinition"
    },
    {
      "name": "AiRmfProfile",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiRmfProfile",
      "description": "An implementation of the AI RMF Functions, Categories, and\nSubcategories for a specific setting or application based on the\nrequirements, risk tolerance, and resources of the user (\u00a76).\nProfiles may be use-case-specific, temporal (current or target),\nor cross-sectoral.",
      "in_subset": [
        "profiles"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "exact_mappings": [
        "oscal_profile:Profile"
      ],
      "close_mappings": [
        "nist_sp_800_53:ProfileDocument"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "profile_type",
        "current_state",
        "target_state",
        "sector",
        "addresses"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiRmfProfile",
      "@type": "ClassDefinition"
    },
    {
      "name": "RmfAttribute",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/RmfAttribute",
      "description": "A design attribute of the AI RMF (Appendix D) - one of the\nqualities the Framework strives to embody (e.g., risk-based,\nconsensus-driven, plain language, common language, easily usable,\nuniversally applicable, outcome-focused, leveraging existing\nstandards, law- and regulation-agnostic, living document).",
      "in_subset": [
        "attributes"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "related_mappings": [
        "nist_csf:CSFProperty"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/RmfAttribute",
      "@type": "ClassDefinition"
    },
    {
      "name": "AiSpecificRisk",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiSpecificRisk",
      "description": "A risk that is new or increased for AI-based technology compared\nto traditional software (Appendix B) - e.g., data quality, model\ndrift, opacity, scale and complexity, pre-trained model\nuncertainty, emergent properties, privacy aggregation, or\nenvironmental cost.",
      "in_subset": [
        "ai_risk_distinctions"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "broad_mappings": [
        "iso27001:Risk"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiSpecificRisk",
      "@type": "ClassDefinition"
    },
    {
      "name": "HumanAiInteractionIssue",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/HumanAiInteractionIssue",
      "description": "An issue that merits further consideration in human-AI\ninteraction (Appendix C) - e.g., clear human roles and\nresponsibilities, systemic and human-cognitive biases in design,\nvariability of human-AI interaction outcomes, complexity of\npresenting AI system information to humans.",
      "in_subset": [
        "human_ai_interaction"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "related_mappings": [
        "iso27001:InterestedParty"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/HumanAiInteractionIssue",
      "@type": "ClassDefinition"
    },
    {
      "name": "PlaybookEntry",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/PlaybookEntry",
      "description": "A single AI RMF Playbook entry - an enrichment of a Core\nsubcategory with prose discussion, suggested actions,\ndocumentation questions, references, and topic tags.\n\nAttribute names use the same identifiers found in the published\nNIST AI RMF Playbook JSON (e.g., `section_about`,\n`section_actions`) so that the data can be loaded directly.",
      "in_subset": [
        "playbook"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "close_mappings": [
        "nist_csf:CSFSubcategory"
      ],
      "slots": [
        "playbookEntry__type",
        "playbookEntry__title",
        "playbookEntry__category",
        "playbookEntry__description",
        "playbookEntry__section_about",
        "playbookEntry__section_actions",
        "playbookEntry__section_doc",
        "playbookEntry__section_ref",
        "playbookEntry__ai_actors",
        "playbookEntry__topic"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "type",
          "description": "Function label as serialised in the published Playbook JSON\n(Title case - \"Govern\", \"Map\", \"Measure\", \"Manage\"). For\nthe controlled enum see `function_kind`.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "title",
          "description": "Subcategory identifier (e.g., \"GOVERN 1.1\"). Mirrors the\nAI RMF Subcategory `subcategory_id`.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "category",
          "description": "Category code in the form \"FUNCTION-N\" (e.g., \"GOVERN-1\")\nas used in the Playbook.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "description",
          "description": "Outcome statement of the subcategory.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "section_about",
          "description": "Free-text discussion (\"About\" section).",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "section_actions",
          "description": "Bulleted suggested actions (\"Actions\" section).",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "section_doc",
          "description": "Documentation questions and transparency resources\n(\"Documentation\" section).",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "section_ref",
          "description": "References and citations (\"References\" section).",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "ai_actors",
          "description": "AI actor categories the entry applies to. Free-text to\npreserve the casing of the source data (e.g., \"Governance\nand Oversight\").",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "topic",
          "description": "Topic tags (e.g., \"Legal and Regulatory\", \"Validity and\nReliability\").",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/PlaybookEntry",
      "unique_keys": [
        {
          "unique_key_name": "primary",
          "unique_key_slots": [
            "title"
          ],
          "@type": "UniqueKey"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "PlaybookCollection",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/PlaybookCollection",
      "description": "A container for a set of PlaybookEntry instances - the\nserialisation root for an AI RMF Playbook companion document.\nValidate with ``linkml-validate --target-class PlaybookCollection``;\nthe canonical tree-root for the schema is ``AiRmfFramework``.",
      "in_subset": [
        "playbook"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "slots": [
        "entries"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/PlaybookCollection",
      "@type": "ClassDefinition"
    },
    {
      "name": "AiRmfDocument",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiRmfDocument",
      "description": "Publication metadata for an instance of the AI RMF (e.g., NIST\nAI 100-1, January 2023). The Framework is intended to be a\nliving document, employing a two-number versioning system (major.minor).",
      "in_subset": [
        "base"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "close_mappings": [
        "nist_csf:CSFMetadata"
      ],
      "related_mappings": [
        "schema:CreativeWork"
