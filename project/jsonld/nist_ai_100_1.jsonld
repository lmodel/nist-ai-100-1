      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiActorTask",
      "@type": "ClassDefinition"
    },
    {
      "name": "Risk",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Risk",
      "description": "The composite measure of an event's probability of occurring and\nthe magnitude or degree of the consequences of that event. When\nconsidering negative impact, risk is a function of (1) the\nnegative impact or magnitude of harm and (2) the likelihood of\noccurrence (Adapted from ISO 31000:2018; OMB Circular A-130:2016).",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "exact_mappings": [
        "iso27001:Risk"
      ],
      "related_mappings": [
        "iso29100:PrivacyRisk"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "likelihood",
        "magnitude",
        "impact_sign",
        "is_residual",
        "risk_response",
        "lifecycle_stage",
        "trustworthiness_characteristic",
        "related_impacts",
        "affects_system"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/Risk",
      "@type": "ClassDefinition"
    },
    {
      "name": "Impact",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Impact",
      "description": "A positive, negative, or both consequence of an AI system. Impacts\ncan manifest as opportunities (positive) or threats (negative).",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "narrow_mappings": [
        "iso27001:ImpactRating"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "impact_sign",
        "magnitude",
        "likelihood",
        "affects"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/Impact",
      "@type": "ClassDefinition"
    },
    {
      "name": "Harm",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Harm",
      "description": "A negative impact that may be experienced by individuals,\ngroups, communities, organizations, society, the environment, or\nthe planet (Figure 1).",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "harm_category",
        "harm_to_people_subcategory",
        "magnitude",
        "affects"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/Harm",
      "@type": "ClassDefinition"
    },
    {
      "name": "ResidualRisk",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/ResidualRisk",
      "description": "Risk remaining after risk treatment (ISO Guide 73). Documenting\nresidual risks helps system providers consider risks of deploying\nthe AI product and informs end users about potential negative\nimpacts.",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "narrow_mappings": [
        "iso27001:Risk"
      ],
      "is_a": "Risk",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "likelihood",
        "magnitude",
        "impact_sign",
        "risk_response",
        "lifecycle_stage",
        "trustworthiness_characteristic",
        "related_impacts",
        "affects_system",
        "ResidualRisk_is_residual"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/ResidualRisk",
      "@type": "ClassDefinition"
    },
    {
      "name": "RiskTolerance",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/RiskTolerance",
      "description": "The organization's or AI actor's readiness to bear risk in order\nto achieve its objectives (Adapted from ISO Guide 73). Risk\ntolerance is highly contextual and application- and use-case\nspecific.",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "close_mappings": [
        "iso27001:RiskLevel"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "tolerance_statement",
        "legal_basis"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/RiskTolerance",
      "@type": "ClassDefinition"
    },
    {
      "name": "RiskMeasurementChallenge",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/RiskMeasurementChallenge",
      "description": "A challenge that complicates measurement of AI risks\n(Part 1 \u00a71.2.1).",
      "in_subset": [
        "risk_and_harm"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "is_a": "NamedThing",
      "slots": [
        "id",
