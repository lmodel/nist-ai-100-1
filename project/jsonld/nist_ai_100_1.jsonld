  "default_prefix": "nist_ai_100_1",
  "default_range": "string",
  "subsets": [
    {
      "name": "framework_core",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/FrameworkCore",
      "description": "The AI RMF Core (Part 2, \u00a75): the four high-level Functions\n(GOVERN, MAP, MEASURE, MANAGE) and their Categories and\nSubcategories - the catalog backbone of the Framework.",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "@type": "SubsetDefinition"
    },
    {
      "name": "lifecycle",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Lifecycle",
      "description": "AI system lifecycle stages, key dimensions, AI actor categories,\nand AI actor tasks (Part 1, \u00a72 Audience; Figures 2 and 3;\nAppendix A \"Descriptions of AI Actor Tasks\").",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "@type": "SubsetDefinition"
    },
    {
      "name": "risk_and_harm",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/RiskAndHarm",
      "description": "Risk, impact, harm, residual risk, risk tolerance, risk\nmeasurement challenges, and risk response options (Part 1, \u00a71\n\"Framing Risk\", incl. \u00a71.2 Challenges).",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "@type": "SubsetDefinition"
    },
    {
      "name": "profiles",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Profiles",
      "description": "AI RMF profile constructs (Part 2, \u00a76): use-case profiles,\ntemporal (current / target) profiles, and cross-sectoral profiles.",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "@type": "SubsetDefinition"
    },
    {
      "name": "attributes",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Attributes",
      "description": "Design attributes of the AI RMF (Appendix D \"Attributes of the\nAI RMF\") - the qualities the Framework strives to embody.",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "@type": "SubsetDefinition"
    },
    {
      "name": "ai_risk_distinctions",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiRiskDistinctions",
      "description": "Appendix B \"How AI Risks Differ from Traditional Software Risks\" -\nrisks that are new or increased for AI-based technology (e.g.,\ndata quality, model drift, opacity, scale and complexity,\npre-trained model uncertainty, emergent properties, privacy\naggregation, environmental cost).",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "@type": "SubsetDefinition"
    },
    {
      "name": "human_ai_interaction",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/HumanAiInteraction",
      "description": "Appendix C \"AI Risk Management and Human-AI Interaction\" -\nconsiderations for human roles and responsibilities, cognitive\nand systemic biases in design, variability of interaction\noutcomes, and presentation of AI information to humans.",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "@type": "SubsetDefinition"
    },
    {
      "name": "playbook",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Playbook",
      "description": "Companion-resource enrichment of an AI RMF subcategory with\nfree-text discussion (\"about\"), suggested actions, documentation\nquestions, and references - modelled after the NIST AI RMF\nPlaybook JSON shape. (Not part of NIST AI 100-1 itself; cross-\nreferenced in Part 2, \u00a75.)",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "@type": "SubsetDefinition"
    },
    {
      "name": "base",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Base",
      "description": "Schema-infrastructure elements shared across the framework:\nidentifier slots and the abstract `NamedThing` root.",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1/schema/nist_ai_rmf_common",
      "@type": "SubsetDefinition"
    },
    {
      "name": "trustworthiness",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/Trustworthiness",
      "description": "Characteristics of trustworthy AI systems (NIST AI 100-1 Part 1,\n\u00a73): Valid and Reliable, Safe, Secure and Resilient, Accountable\nand Transparent, Explainable and Interpretable, Privacy-Enhanced,\nand Fair with Harmful Bias Managed.",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1/schema/nist_ai_rmf_common",
      "@type": "SubsetDefinition"
    }
  ],
  "types": [
    {
      "name": "FunctionCode",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/FunctionCode",
      "description": "Identifier of one of the four AI RMF Core functions.",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "typeof": "string",
      "base": "str",
      "uri": "http://www.w3.org/2001/XMLSchema#string",
      "pattern": "^(GOVERN|MAP|MEASURE|MANAGE)$",
      "@type": "TypeDefinition"
    },
    {
      "name": "CategoryCode",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/CategoryCode",
      "description": "Identifier for a Core category (e.g., \"GOVERN 1\", \"MAP 3\").",
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "typeof": "string",
      "base": "str",
      "uri": "http://www.w3.org/2001/XMLSchema#string",
      "pattern": "^(GOVERN|MAP|MEASURE|MANAGE) [0-9]+$",
      "@type": "TypeDefinition"
    },
