      "description": "An engineered or machine-based system that can, for a given set\nof objectives, generate outputs such as predictions,\nrecommendations, or decisions influencing real or virtual\nenvironments. AI systems are designed to operate with varying\nlevels of autonomy (Adapted from OECD Recommendation on AI:2019;\nISO/IEC 22989:2022).",
      "in_subset": [
        "lifecycle"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "close_mappings": [
        "schema:SoftwareApplication"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "lifecycle_stage",
        "ai_dimension"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiSystem",
      "@type": "ClassDefinition"
    },
    {
      "name": "AiSystemDimension",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiSystemDimension",
      "description": "A socio-technical dimension of an AI system (Figure 2):\nApplication Context, Data and Input, AI Model, Task and Output,\nor People and Planet.",
      "in_subset": [
        "lifecycle"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "dimension_kind"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiSystemDimension",
      "@type": "ClassDefinition"
    },
    {
      "name": "AiLifecycleStage",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiLifecycleStage",
      "description": "A stage of the AI lifecycle (Figure 2): Plan and Design,\nCollect and Process Data, Build and Use Model, Verify and\nValidate, Deploy and Use, or Operate and Monitor.",
      "in_subset": [
        "lifecycle"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "stage_kind",
        "includes_tevv"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiLifecycleStage",
      "@type": "ClassDefinition"
    },
    {
      "name": "AiActor",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiActor",
      "description": "An organization or individual that plays an active role in the AI\nsystem lifecycle. AI actors include those who deploy or operate\nAI as well as those who inform via formal or quasi-formal norms\nand guidance (OECD 2019).",
      "in_subset": [
        "lifecycle"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "close_mappings": [
        "prov:Agent",
        "foaf:Agent"
      ],
      "related_mappings": [
        "stix:Identity",
        "iso27001:InterestedParty"
      ],
      "is_a": "NamedThing",
      "slots": [
        "id",
        "name",
        "title",
        "description",
        "see_also",
        "actor_task",
        "lifecycle_stage",
        "is_tevv",
        "audience"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiActor",
      "@type": "ClassDefinition"
    },
    {
      "name": "AiActorTask",
      "definition_uri": "https://w3id.org/lmodel/nist-ai-100-1/AiActorTask",
      "description": "A category of task performed by AI actors (Appendix A). Each\ntask is associated with one or more lifecycle stages and a\ntypical set of actor roles.",
      "in_subset": [
        "lifecycle"
      ],
      "from_schema": "https://w3id.org/lmodel/nist-ai-100-1",
      "is_a": "NamedThing",
      "slots": [
        "id",
